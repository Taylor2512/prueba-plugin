{
  "name": "@pdfme/converter",
  "version": "0.0.0",
  "sideEffects": false,
  "author": "hand-dot",
  "license": "MIT",
  "keywords": [
    "pdf",
    "pdf-generation",
    "pdf-designer",
    "pdf-viewer",
    "typescript",
    "react"
  ],
  "description": "TypeScript base PDF generator and React base UI. Open source, developed by the community, and completely free to use under the MIT license!",
  "homepage": "https://pdfme.com",
  "repository": {
    "type": "git",
    "url": "git@github.com:pdfme/pdfme.git"
  },
  "bugs": {
    "url": "https://github.com/pdfme/pdfme/issues"
  },
  "main": "./dist/cjs/index.browser.js",
  "module": "./dist/esm/index.browser.js",
  "types": "./src/index.browser.ts",
  "exports": {
    ".": {
      "types": "./src/index.browser.ts",
      "import": "./dist/esm/index.browser.js",
      "require": "./dist/cjs/index.browser.js"
    },
    "./node": {
      "types": "./src/index.node.ts",
      "import": "./dist/esm/index.node.js",
      "require": "./dist/cjs/index.node.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rm -rf dist && npm run build:esm && npm run build:cjs",
    "build:esm": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/esm --outbase=src --format=esm --platform=neutral --target=es2020 --sourcemap",
    "build:cjs": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/cjs --outbase=src --format=cjs --platform=neutral --target=es2020 --sourcemap"
  },
  "dependencies": {
    "@pdfme/common": "*",
    "@pdfme/pdf-lib": "*",
    "pdfjs-dist": "2.16.105"
  },
  "publishConfig": {
    "access": "public"
  }
}
