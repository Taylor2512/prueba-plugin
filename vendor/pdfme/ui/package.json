{
  "name": "@pdfme/ui",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "author": "hand-dot",
  "license": "MIT",
  "keywords": [
    "pdf",
    "pdf-generation",
    "pdf-designer",
    "pdf-viewer",
    "typescript",
    "react"
  ],
  "description": "TypeScript base PDF generator and React base UI. Open source, developed by the community, and completely free to use under the MIT license!",
  "homepage": "https://pdfme.com",
  "repository": {
    "type": "git",
    "url": "git@github.com:pdfme/pdfme.git"
  },
  "bugs": {
    "url": "https://github.com/pdfme/pdfme/issues"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rm -rf dist && npm run build:esm && npm run build:cjs && npm run copy:styles",
    "build:esm": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/esm --outbase=src --format=esm --platform=neutral --target=es2020 --sourcemap",
    "build:cjs": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/cjs --outbase=src --format=cjs --platform=neutral --target=es2020 --sourcemap",
    "copy:styles": "node ./scripts/copy-styles.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/sortable": "^10.0.0",
    "@pdfme/converter": "*",
    "@scena/react-guides": "^0.28.2",
    "antd": "^5.27.4",
    "dompurify": "^3.3.1",
    "form-render": "^2.5.5",
    "globrex": "^0.1.2",
    "hotkeys-js": "^3.13.15",
    "lucide-react": "^0.563.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-moveable": "^0.56.0",
    "react-refresh": "^0.18.0",
    "react-selecto": "^1.12.0"
  },
  "peerDependencies": {
    "@pdfme/common": "*",
    "@pdfme/schemas": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}