{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@sisad-pdfme/*": [
        "src/components/sisad-pdfme/*/src"
      ],
      "@sisad-pdfme/converter": [
        "src/components/sisad-pdfme/converter/index.browser.ts"
      ],
      "@sisad-pdfme/pdf-lib": [
        "src/components/sisad-pdfme/pdf-lib"
      ]
    },
    "types": [
      "vite/client",
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src",
    "tests",
    "vite.config.*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
