{
  "name": "@pdfme/pdf-lib",
  "version": "0.0.0",
  "sideEffects": false,
  "author": "hand-dot",
  "license": "MIT",
  "keywords": [
    "pdf-lib",
    "pdf",
    "document",
    "create",
    "modify",
    "creation",
    "modification",
    "edit",
    "editing",
    "typescript",
    "javascript",
    "library"
  ],
  "description": "Create and modify PDF files with JavaScript",
  "homepage": "https://pdfme.com",
  "repository": {
    "type": "git",
    "url": "git@github.com:pdfme/pdfme.git"
  },
  "bugs": {
    "url": "https://github.com/pdfme/pdfme/issues"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rm -rf dist && npm run build:esm && npm run build:cjs",
    "build:esm": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/esm --outbase=src --format=esm --platform=neutral --target=es2020 --sourcemap",
    "build:cjs": "npm exec -- esbuild $(find src \\( -name '*.ts' -o -name '*.tsx' \\)) --outdir=dist/cjs --outbase=src --format=cjs --platform=neutral --target=es2020 --sourcemap"
  },
  "dependencies": {
    "@pdf-lib/standard-fonts": "^1.0.0",
    "@pdf-lib/upng": "^1.0.1",
    "color": "^4.2.3",
    "node-html-better-parser": "^1.5.8",
    "pako": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
